@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-5">

    <h1 class="display-5 fw-bold text-primary">
        Cryptography Demo
    </h1>

    <p class="text-muted">
        Demo các thuật toán mật mã trong môn An toàn bảo mật thông tin
    </p>

</div>

<div class="row g-4">

    <div class="col-md-4">

        <div class="card shadow-sm h-100">
            <div class="card-body text-center">

                <h4 class="card-title">DES</h4>

                <p class="text-muted">
                    Data Encryption Standard
                </p>

                <a href="/DES" class="btn btn-primary">
                    Thử ngay
                </a>

            </div>
        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm h-100">
            <div class="card-body text-center">

                <h4 class="card-title">AES</h4>

                <p class="text-muted">
                    Advanced Encryption Standard
                </p>

                <a href="/AES" class="btn btn-primary">
                    Thử ngay
                </a>

            </div>
        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm h-100">
            <div class="card-body text-center">

                <h4 class="card-title">Mã hóa</h4>

                <p class="text-muted">
                    Caesar, Vigenere lặp khóa, Vigenere khóa tự động, Playfair
                </p>

                <a href="/Classical/Encrypt" class="btn btn-primary">
                    Thử ngay
                </a>

            </div>
        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm h-100">
            <div class="card-body text-center">

                <h4 class="card-title">Giải mã</h4>

                <p class="text-muted">
                    Caesar, Vigenere lặp khóa, Vigenere khóa tự động, Playfair
                </p>

                <a href="/Classical/Decrypt" class="btn btn-primary">
                    Thử ngay
                </a>

            </div>
        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm h-100">
            <div class="card-body text-center">

                <h4 class="card-title">Hàm Euler</h4>

                <p class="text-muted">
                    Tính φ(n)
                </p>

                <a href="/Euler/EulerCalc" class="btn btn-primary">
                    Thử ngay
                </a>

            </div>
        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow-sm h-100">
            <div class="card-body text-center">

                <h4 class="card-title">ElGamal</h4>

                <p class="text-muted">
                    Public Key Cryptography
                </p>

                <a href="/ElGamal" class="btn btn-primary">
                    Thử ngay
                </a>

            </div>
        </div>

    </div>

</div>